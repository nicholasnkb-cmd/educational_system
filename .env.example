HOSTINGER_SFTP_HOST=ftp.educationalsystem.fieldserviceit.com
HOSTINGER_SFTP_PORT=65002
HOSTINGER_SFTP_USER=u209468809
HOSTINGER_SFTP_PASSWORD=replace-with-hostinger-sftp-password
HOSTINGER_REMOTE_DIR=/home/u209468809/domains/educationalsystem.fieldserviceit.com/public_html
HOSTINGER_API_REMOTE_DIR=/home/u209468809/domains/educationalsystem.fieldserviceit.com/public_html/educonnect-api
LIVE_BASE_URL=https://educationalsystem.fieldserviceit.com
VITE_API_BASE_URL=https://api.educationalsystem.fieldserviceit.com
EDUCONNECT_BOOTSTRAP_GLOBAL_ADMIN=replace-with-a-unique-strong-password
EDUCONNECT_BOOTSTRAP_STATE_ADMIN=replace-with-a-unique-strong-password
EDUCONNECT_BOOTSTRAP_DISTRICT_ADMIN=replace-with-a-unique-strong-password
EDUCONNECT_BOOTSTRAP_SCHOOL_ADMIN=replace-with-a-unique-strong-password
EDUCONNECT_BOOTSTRAP_TEACHER=replace-with-a-unique-strong-password
EDUCONNECT_BOOTSTRAP_PARENT=replace-with-a-unique-strong-password
EDUCONNECT_BOOTSTRAP_STUDENT=replace-with-a-unique-strong-password

# Production data platform. Apply database/postgres migrations before enabling.
DATABASE_URL=postgresql://educonnect_app:replace-me@database-host:5432/educonnect

# S3-compatible school media and encrypted offsite backup storage (AWS S3 or Cloudflare R2).
EDUCONNECT_OBJECT_STORAGE_ENDPOINT=https://replace-me.example
EDUCONNECT_OBJECT_STORAGE_BUCKET=replace-with-private-bucket
EDUCONNECT_OBJECT_STORAGE_KEY=replace-with-access-key
EDUCONNECT_OBJECT_STORAGE_SECRET=replace-with-secret-key

# Transactional communications. Configure only the channels approved by each school.
EDUCONNECT_EMAIL_PROVIDER=postmark
EDUCONNECT_EMAIL_API_KEY=replace-with-provider-key
EDUCONNECT_EMAIL_FROM=school@example.org
EDUCONNECT_TWILIO_ACCOUNT_SID=replace-with-account-sid
EDUCONNECT_TWILIO_AUTH_TOKEN=replace-with-auth-token
EDUCONNECT_TWILIO_FROM=replace-with-sending-number
EDUCONNECT_WEB_PUSH_PUBLIC_KEY=replace-with-vapid-public-key
EDUCONNECT_WEB_PUSH_PRIVATE_KEY=replace-with-vapid-private-key

# Privileged authentication, upload scanning, and operational alerts.
EDUCONNECT_TOTP_ENCRYPTION_KEY=replace-with-32-byte-or-longer-key
EDUCONNECT_CLAMAV_HOST=127.0.0.1
EDUCONNECT_CLAMAV_PORT=3310
EDUCONNECT_ERROR_WEBHOOK_URL=https://replace-with-private-alert-endpoint.example

# Optional hosted roster, identity, and classroom integrations.
EDUCONNECT_ONEROSTER_BASE_URL=https://sis.example.org/ims/oneroster/v1p2
EDUCONNECT_ONEROSTER_CLIENT_ID=replace-with-client-id
EDUCONNECT_ONEROSTER_CLIENT_SECRET=replace-with-client-secret
EDUCONNECT_GOOGLE_CLIENT_ID=replace-with-client-id
EDUCONNECT_GOOGLE_CLIENT_SECRET=replace-with-client-secret
EDUCONNECT_MICROSOFT_TENANT_ID=replace-with-tenant-id
EDUCONNECT_MICROSOFT_CLIENT_ID=replace-with-client-id
EDUCONNECT_MICROSOFT_CLIENT_SECRET=replace-with-client-secret
EDUCONNECT_CLEVER_CLIENT_ID=replace-with-client-id
EDUCONNECT_CLEVER_CLIENT_SECRET=replace-with-client-secret
EDUCONNECT_CLASSLINK_TENANT_ID=replace-with-tenant-id
EDUCONNECT_CLASSLINK_CLIENT_ID=replace-with-client-id
EDUCONNECT_CLASSLINK_CLIENT_SECRET=replace-with-client-secret
