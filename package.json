{
  "name": "educational-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "node server.mjs",
    "serve:operational": "npm run build && node server.mjs",
    "build": "vite build",
    "build:hostinger": "vite build --base=/",
    "deploy:hostinger": "npm run build:hostinger && node scripts/deploy-hostinger.js",
    "deploy:hostinger:api": "node scripts/deploy-hostinger-api.js",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run test:config && npm run test:ui && npm run test:api",
    "test:config": "node --test tests/api-config.test.mjs",
    "test:ui": "playwright test",
    "test:accessibility": "playwright test tests/accessibility.spec.js",
    "test:api": "node --test tests/api.test.mjs",
    "audit:lighthouse": "node scripts/lighthouse-audit.mjs",
    "test:live": "playwright test -c playwright.live.config.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "lucide": "^0.468.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.49.1",
    "lighthouse": "^12.6.1",
    "ssh2-sftp-client": "^11.0.0",
    "vite": "^6.0.1"
  }
}
